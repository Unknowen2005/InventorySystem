<Page x:Class="Inventory.WPF.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Dashboard"
      Background="#F8F9FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Bem-vindo ao Inventory System!" 
                           FontSize="26" 
                           FontWeight="SemiBold" 
                           Foreground="#2D3748"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Versão 1.2.0" FontSize="13" Foreground="#A0AEC0"/>
                    <TextBlock Text=" • " FontSize="13" Foreground="#A0AEC0"/>
                    <TextBlock Text="{Binding Titulo}" FontSize="13" Foreground="#718096" FontWeight="Medium"/>
                </StackPanel>
            </StackPanel>

            <Button Content="Sair do Sistema" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center"
                    Padding="16,10" 
                    Background="#FFF5F5" 
                    Foreground="#E53E3E"
                    BorderBrush="#FED7D7"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Click="Sair_Click"
                    >
                
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,20">
                <Border Background="White" Margin="0,0,12,0" Padding="20" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total de Produtos" FontSize="14" Foreground="#718096" FontWeight="Medium"/>
                        <TextBlock Text="1,248" FontSize="28" FontWeight="Bold" Foreground="#2D3748" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" Margin="6,0,6,0" Padding="20" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Itens com Alerta de Estoque" FontSize="14" Foreground="#718096" FontWeight="Medium"/>
                        <TextBlock Text="12" FontSize="28" FontWeight="Bold" Foreground="#E53E3E" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" Margin="12,0,0,0" Padding="20" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Movimentações (Hoje)" FontSize="14" Foreground="#718096" FontWeight="Medium"/>
                        <TextBlock Text="+ 45" FontSize="28" FontWeight="Bold" Foreground="#38A169" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="1" Background="White" Padding="24" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <TextBlock Text="Dashboard - Estatísticas Detalhadas do Estoque" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Foreground="#4A5568"
                               HorizontalAlignment="Left" 
                               VerticalAlignment="Top"/>

                    <TextBlock Text="Nenhuma atividade suspeita ou pendente para exibir." 
                               FontSize="14" 
                               Foreground="#A0AEC0" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Separator VerticalAlignment="Top" Background="#E2E8F0"/>
            <TextBlock Text="Desenvolvido por DEPARTAMENTO DE PESQUISAS" 
                       FontSize="12" 
                       Foreground="#A0AEC0" 
                       HorizontalAlignment="Center" 
                       Margin="0,12,0,0"/>
        </Grid>
    </Grid>
</Page>