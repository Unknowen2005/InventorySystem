<Page x:Class="Inventory.WPF.Views.Account.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Login"
      Background="White">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
        <StackPanel>
            <TextBlock Text="Inventory System" FontSize="28" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Email" FontSize="14" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="10" FontSize="14" Margin="0,0,0,15"/>

            <TextBlock Text="Senha" FontSize="14" Margin="0,0,0,5"/>
            <PasswordBox x:Name="SenhaBox" Padding="10" FontSize="14" Margin="0,0,0,20"/>

            <Button Content="Entrar" 
                    Command="{Binding LoginCommand}"
                    CommandParameter="{Binding ElementName=SenhaBox}"
                    FontSize="16" FontWeight="Bold"
                    Background="#3498DB" Foreground="White"
                    Padding="15" Margin="0,0,0,10"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock Text="{Binding MensagemErro}" 
                       Foreground="Red" 
                       HorizontalAlignment="Center" 
                       FontSize="14" 
                       TextWrapping="Wrap"
                       Visibility="{Binding MensagemErro, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}"/>

            <TextBlock Text="{Binding IsLoading, Converter={StaticResource BoolToLoadingText}}" 
                       HorizontalAlignment="Center" Foreground="Gray" FontSize="12" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</Page>